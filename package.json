{
  "name": "sp-api",
  "version": "1.4.0",
  "description": "Agentic SharePoint CLI with a bundled thin skill for coding agents",
  "bin": {
    "sp-api": "bin/sp-api.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "prepare": "npm run build",
    "link:local": "npm run build && npm link",
    "test": "node --test tests/test-scripts.js tests/test-sp-api.js",
    "test:integration": "node --test tests/test-integration.js",
    "auth": "sp-api auth status",
    "login": "sp-api auth login",
    "logout": "sp-api auth logout"
  },
  "dependencies": {
    "playwright": "^1.50.0"
  },
  "keywords": [
    "sharepoint",
    "claude",
    "copilot",
    "codex",
    "ai",
    "skill",
    "mcp",
    "api"
  ],
  "author": "Marcus Markiewicz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/supermem613/sp-api"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
